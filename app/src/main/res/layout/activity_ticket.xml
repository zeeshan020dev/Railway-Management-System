<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d1b2a">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1e2d3d"
            android:padding="16dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_weight="1">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="E-Ticket"
                    android:textColor="#90caf9"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/tvRouteInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lahore → Karachi"
                    android:textColor="#ffffff"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Status Badge -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ CONFIRMED"
                android:textColor="#4caf50"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="#1b3a1b"
                android:padding="8dp"/>
        </LinearLayout>

        <!-- Ticket Card - Green Header -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#1e2d3d"
            app:cardElevation="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Green Top Banner -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#1b5e20"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚂  Pakistan Railway"
                        android:textColor="#ffffff"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Official E-Ticket"
                        android:textColor="#a5d6a7"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"/>

                    <!-- Booking ID -->
                    <TextView
                        android:id="@+id/tvBookingId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Booking ID: ABC123"
                        android:textColor="#ffffff"
                        android:textSize="11sp"
                        android:layout_marginTop="6dp"
                        android:alpha="0.8"/>
                </LinearLayout>

                <!-- Route Big Text -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FROM"
                            android:textColor="#90caf9"
                            android:textSize="10sp"/>

                        <TextView
                            android:id="@+id/tvFromCity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lahore"
                            android:textColor="#ffffff"
                            android:textSize="22sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✈"
                        android:textColor="#4caf50"
                        android:textSize="28sp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TO"
                            android:textColor="#90caf9"
                            android:textSize="10sp"/>

                        <TextView
                            android:id="@+id/tvToCity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Karachi"
                            android:textColor="#ffffff"
                            android:textSize="22sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Dashed Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#263545"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"/>

                <!-- Train + Class Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TRAIN"
                            android:textColor="#90caf9"
                            android:textSize="10sp"/>

                        <TextView
                            android:id="@+id/tvTrainInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Karachi Express"
                            android:textColor="#ffffff"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CLASS"
                            android:textColor="#90caf9"
                            android:textSize="10sp"/>

                        <TextView
                            android:id="@+id/tvClassInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Economy"
                            android:textColor="#ffffff"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Departure + Arrival -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DEPARTURE"
                            android:textColor="#90caf9"
                            android:textSize="10sp"/>

                        <TextView
                            android:id="@+id/tvDepartureInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="08:00 AM"
                            android:textColor="#ffffff"
                            android:textSize="18sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ARRIVAL"
                            android:textColor="#90caf9"
                            android:textSize="10sp"/>

                        <TextView
                            android:id="@+id/tvArrivalInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="08:00 PM"
                            android:textColor="#ffffff"
                            android:textSize="18sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Seats -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#263545"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SEATS"
                        android:textColor="#90caf9"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tvSeatsInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="S1, S2, S3"
                        android:textColor="#ffffff"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Total Fare -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="TOTAL FARE"
                        android:textColor="#4caf50"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvTotalFare"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rs. 3000"
                        android:textColor="#4caf50"
                        android:textSize="26sp"
                        android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Download PDF Button -->
        <Button
            android:id="@+id/btnDownloadPdf"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            android:text="⬇  DOWNLOAD PDF TICKET"
            android:textColor="#ffffff"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#1565c0"/>

        <!-- My Bookings Button -->
        <Button
            android:id="@+id/btnMyBookings"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            android:text="MY BOOKINGS"
            android:textColor="#ffffff"
            android:textSize="15sp"
            android:backgroundTint="#37474f"/>

        <!-- Home Button -->
        <Button
            android:id="@+id/btnHome"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp"
            android:text="GO TO HOME"
            android:textColor="#ffffff"
            android:textSize="15sp"
            android:backgroundTint="#1b5e20"/>

    </LinearLayout>
</ScrollView>