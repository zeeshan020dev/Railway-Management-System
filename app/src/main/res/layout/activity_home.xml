<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#0d1b2a">

    <!-- Top Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1e2d3d"
        android:padding="16dp"
        android:paddingTop="24dp"
        android:gravity="center_vertical">

        <!-- Welcome Text -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_weight="1">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚂 Railway App"
                android:textColor="#90caf9"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome!"
                android:textColor="#ffffff"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Logout Button -->
        <TextView
            android:id="@+id/tvLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:textColor="#ef5350"
            android:textSize="14sp"
            android:padding="8dp"/>

    </LinearLayout>

    <!-- Select Route Title -->
    <TextView
        android:id="@+id/tvSelectRoute"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Your Route"
        android:textColor="#ffffff"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_below="@id/header"
        android:layout_marginStart="16dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose from available routes"
        android:textColor="#90caf9"
        android:textSize="13sp"
        android:layout_below="@id/tvSelectRoute"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="16dp"/>

    <!-- Routes RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRoutes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tvSubtitle"
        android:layout_marginTop="14dp"
        android:clipToPadding="false"
        android:padding="8dp" />

</RelativeLayout>