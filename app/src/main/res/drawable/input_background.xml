<?xml version="1.0" encoding="utf-8"?>
<!-- Shape drawable - EditText ka custom background -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color - dark input field -->
    <solid android:color="#263545"/>

    <!-- Border - thin blue line around input -->
    <stroke
        android:width="1dp"
        android:color="#1565c0"/>

    <!-- Rounded corners - professional look -->
    <corners android:radius="8dp"/>

</shape>